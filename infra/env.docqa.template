# Doc-QA full-stack compose environment
# Copy to .env and fill in secrets before running docker compose

# ── shipany ────────────────────────────────────────────────────────────────
VITE_APP_URL=https://your-domain.com
VITE_APP_NAME=DocQA
DATABASE_URL=postgresql://shipany:shipany@postgres:5432/shipany
DATABASE_PROVIDER=postgres
AUTH_SECRET=change-me-long-random
CONFIG_ENCRYPTION_KEY=

# Storage (S3-compatible)
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
DOC_QA_BUCKET=doc-qa

# Email
RESEND_API_KEY=
RESEND_SENDER_EMAIL=

# ── Doc-QA services ─────────────────────────────────────────────────────────
WORKSPACES_ROOT=/data/workspaces
PI_AGENT_WEB_URL=http://pi-agent-web:8504
GATEWAY_PORT=8520
MINERU_URL=http://mineru:8530
INTERNAL_API_TOKEN=change-me-long-random
CREDIT_COST_PER_PROMPT=1
SHIPANY_URL=http://shipany:3000

# LLM (lives only in pi-agent-web, never sent to the browser)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── pi-agent-web ─────────────────────────────────────────────────────────────
PI_AGENT_WEB_HOST=127.0.0.1
PI_AGENT_WEB_PORT=8504
PI_AGENT_WEB_DATA_DIR=/data/pi-agent-web
PI_AGENT_WEB_ALLOWED_ORIGINS=https://your-domain.com
